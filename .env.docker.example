# 复制本文件为仓库根目录的 .env.docker（不要命名为 .env，避免与本地开发共用根目录 .env）。
# 启动时使用：docker compose --env-file .env.docker up -d --build
# （--env-file 同时用于 compose 文件内 ${VAR} 插值；勿依赖默认 .env）。
#
# Copy content to .env.docker next to docker-compose.yml. Do not commit real secrets.

# Required: IP or hostname that browsers use to reach this host (no http://).
# Examples: 192.168.1.100 (LAN), or host.docker.internal (single-machine Docker Desktop).
# Do not use 127.0.0.1 here — other containers cannot use it to reach MinIO on the host.
HOST_IP=192.168.1.100

MYSQL_PASSWORD=changeme-strong-mysql
MYSQL_DB=review

JWT_SECRET=generate-a-long-random-string

MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=review

# Must match onlyoffice service JWT in docker-compose.yml
ONLYOFFICE_JWT_SECRET=change-me-onlyoffice-jwt-secret

# Optional first admin (see backend README)
ADMIN_BOOTSTRAP=false
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_PHONE=13800000000
