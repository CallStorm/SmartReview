# 本地开发：复制本文件为 backend/.env（勿用仓库根目录 .env，以免与 Docker 混用）。
# Copy to backend/.env (or export in shell). Do not commit real secrets.

MYSQL_USER=root
MYSQL_PASSWORD=changeme
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=review

JWT_SECRET=generate-a-long-random-string

# Comma-separated browser origins for CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=review
MINIO_SECURE=false

# Optional: create first admin on API startup (username must not exist)
ADMIN_BOOTSTRAP=false
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_PHONE=13800000000

# Dify 知识库 API（可选；亦可在系统「设置」中配置）
# 示例: http://10.73.2.13/v1
DIFY_BASE_URL=
DIFY_API_KEY=

# 大模型（可选；数据库「设置」优先）
# DEFAULT_LLM_PROVIDER=volcengine | minimax | deepseek
# VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# VOLCENGINE_API_KEY=
# VOLCENGINE_ENDPOINT_ID=
# MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
# MINIMAX_API_KEY=
# MINIMAX_MODEL=MiniMax-M2.7
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-flash

# OnlyOffice（可选；优先在系统「设置 → OnlyOffice」中配置）
# ONLYOFFICE_DOCS_URL=http://127.0.0.1:9080
# ONLYOFFICE_JWT_SECRET=与 Document Server local.json 中 JWT secret 一致
# ONLYOFFICE_CALLBACK_BASE_URL=http://127.0.0.1:8000
# ONLYOFFICE_EDITOR_LANG=zh

# --- Docker Compose（与本地 backend/.env 分开）---
# 复制 .env.docker.example 为仓库根目录的 .env.docker（不要命名为 .env）。
# 填写 HOST_IP、MYSQL_PASSWORD、JWT_SECRET、ONLYOFFICE_JWT_SECRET 等。
# CORS / ONLYOFFICE_DOCS_URL / MINIO_ENDPOINT 使用 ${HOST_IP} 在 compose 中拼接。
# 启动：docker compose --env-file .env.docker up -d --build
